<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <title>Ombor Boshqaruvi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-3">
<div class="container" style="max-width: 600px;">
    <div class="card p-3 mb-4 shadow-sm">
        <form action="/meva/qoshish" method="POST" class="row g-2">
            <div class="col-4"><input type="text" name="nomi" class="form-control" placeholder="Meva nomi" required></div>
            <div class="col-3"><input type="number" name="soni" class="form-control" placeholder="Soni" required></div>
            <div class="col-3"><input type="number" name="narxi" class="form-control" placeholder="Narxi" required></div>
            <div class="col-2"><button class="btn btn-primary w-100">+</button></div>
        </form>
    </div>

    <div class="bg-white p-3 rounded shadow-sm">
        <table class="table" id="mevalarTable">
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" class="form-control" onchange="save('<%= m.id %>', this.value, '<%= m.narxi %>')"></td>
                    <td><a href="/meva/ochirish/<%= m.id %>" class="text-danger">O'chirish</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<script>
    function save(id, soni, narxi) {
        fetch('/meva/tahrirlash/'+id, { 
            method: 'POST', 
            headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ soni, narxi }) 
        }).then(() => location.reload());
    }
</script>
</body>
</html>