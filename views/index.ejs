<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fruit Ombor Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            margin: 0;
            padding: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container { width: 100%; max-width: 850px; }

        /* TEPADAGI NAV */
        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .logo { font-size: 16px; font-weight: 800; color: #10b981; }
        
        .btn-main {
            background: #10b981; color: white; border: none; padding: 5px 12px;
            border-radius: 5px; cursor: pointer; font-weight: 600; font-size: 12px;
        }

        /* 4 BAROVAR KICHRAYTIRILGAN MINI PANEL */
        .mini-stat-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 4px 12px;
            margin-bottom: 10px;
            height: 38px; /* O'ta ixcham balandlik */
            box-sizing: border-box;
        }

        .stat-left { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; color: #475569; }
        .chart-micro-box { width: 22px; height: 22px; display: flex; align-items: center; } /* Micro Grafik */

        .total-right { display: flex; align-items: center; gap: 6px; font-size: 12px; }
        .total-label { color: #64748b; font-weight: 500; }
        .total-value { font-weight: 700; color: #10b981; }

        /* POISK (QIDIRUV) */
        .search-row { margin-bottom: 10px; position: relative; }
        .search-input {
            width: 100%; padding: 8px 12px 8px 34px; border-radius: 6px;
            border: 1px solid #cbd5e1; background: #ffffff; font-size: 13px; outline: none;
            box-sizing: border-box;
        }
        .search-input:focus { border-color: #10b981; }
        .search-icon { position: absolute; left: 10px; top: 8px; color: #94a3b8; font-size: 13px; }

        /* JADVAL */
        .table-card {
            background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; overflow: hidden;
        }
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        th { background: #f8fafc; padding: 10px; text-align: left; color: #64748b; font-weight: 600; border-bottom: 1px solid #e2e8f0; }
        td { padding: 6px 12px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
        tr:hover { background-color: #f8fafc; }
        
        /* RAMKASIZ INPUTLAR */
        .borderless-input {
            border: 1px solid transparent; background: transparent;
            padding: 4px; font-size: 13px; width: 60px; outline: none;
            border-radius: 4px; font-weight: 500;
        }
        .borderless-input:focus { border-color: #10b981; background: #f0fdf4; }

        .check-custom { width: 15px; height: 15px; accent-color: #10b981; cursor: pointer; }

        /* AMALLAR (EDIT & DEL) */
        .actions-group { display: flex; gap: 5px; justify-content: flex-end; }
        
        .btn-action-save {
            background: #e6f4ea; color: #137333; border: none; 
            padding: 4px 8px; border-radius: 4px; font-size: 11px; 
            font-weight: 600; cursor: pointer;
        }
        .btn-action-save:hover { background: #137333; color: white; }

        .btn-action-del {
            background: #fce8e6; color: #c5221f; border: none; 
            padding: 4px 8px; border-radius: 4px; font-size: 11px; 
            font-weight: 600; cursor: pointer; text-decoration: none;
        }
        .btn-action-del:hover { background: #c5221f; color: white; }

        #addForm { display: none; padding: 12px; background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 10px; }
    </style>
</head>
<body>

<div class="container">
    
    <div class="top-nav">
        <div class="logo">FRUIT OMBOR</div>
        <div style="display: flex; gap: 8px;">
            <button class="btn-main" onclick="toggleForm()">+ Qo'shish</button>
            <a href="/logout" style="font-size: 12px; color: #ef4444; text-decoration: none; font-weight: 600; align-self: center; padding: 2px 5px;">Chiqish</a>
        </div>
    </div>

    <div class="mini-stat-bar">
        <div class="stat-left">
            <div class="chart-micro-box">
                <canvas id="miniChart"></canvas>
            </div>
            <span>Ombor zaxirasi</span>
        </div>
        
        <div class="total-right">
            <span class="total-label">Tanlangan jami:</span>
            <span class="total-value" id="totalDisplay">0 so'm</span>
        </div>
    </div>

    <div id="addForm">
        <form action="/meva/qoshish" method="POST" style="display: flex; gap: 6px;">
            <input type="text" name="nomi" placeholder="Meva nomi" style="flex: 1; padding: 6px; border-radius: 4px; border: 1px solid #cbd5e1;" required>
            <input type="number" name="soni" placeholder="Soni" style="width: 50px; padding: 6px; border-radius: 4px; border: 1px solid #cbd5e1;" required>
            <input type="number" name="narxi" placeholder="Narxi" style="width: 90px; padding: 6px; border-radius: 4px; border: 1px solid #cbd5e1;" required>
            <button type="submit" class="btn-main">Saqlash</button>
        </form>
    </div>

    <div class="search-row">
        <span class="search-icon">🔍</span>
        <input type="text" id="searchInput" class="search-input" placeholder="Meva nomini yozib qidiring..." oninput="liveSearch()">
    </div>

    <div class="table-card">
        <table id="mevaTable">
            <thead>
                <tr>
                    <th style="width: 20px;"></th>
                    <th>Nomi</th>
                    <th style="width: 75px;">Soni</th>
                    <th style="width: 100px;">Narxi (so'm)</th>
                    <th style="width: 110px; text-align: right;">Amallar</th>
                </tr>
            </thead>
            <tbody>
                <% if (mevalar && mevalar.length > 0) { %>
                    <% mevalar.forEach((meva) => { %>
                        <tr class="meva-row">
                            <td>
                                <input type="checkbox" class="check-custom" 
                                       data-price="<%= meva.narxi %>" 
                                       data-count="<%= meva.soni %>"
                                       onchange="calculateTotal()">
                            </td>
                            <td class="meva-name" style="font-weight: 600; color: #334155;"><%= meva.nomi %></td>
                            <form action="/meva/tahrirlash/<%= meva.id %>" method="POST">
                                <td><input type="number" name="soni" class="borderless-input" value="<%= meva.soni %>" required></td>
                                <td><input type="number" name="narxi" class="borderless-input" style="width: 75px;" value="<%= meva.narxi %>" required></td>
                                <td>
                                    <div class="actions-group">
                                        <button type="submit" class="btn-action-save">Edit</button>
                                        <a href="/meva/ochirish/<%= meva.id %>" class="btn-action-del" onclick="return confirm('O\'chirilsinmi?')">Del</a>
                                    </div>
                                </td>
                            </form>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" style="text-align: center; padding: 15px; color: #94a3b8;">Mavjud emas.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleForm() {
        const f = document.getElementById('addForm');
        f.style.display = (f.style.display === 'block') ? 'none' : 'block';
    }

    function liveSearch() {
        const filter = document.getElementById('searchInput').value.toLowerCase().trim();
        const rows = document.querySelectorAll('.meva-row');
        rows.forEach(row => {
            const name = row.querySelector('.meva-name').textContent.toLowerCase();
            row.style.display = name.includes(filter) ? "" : "none";
        });
    }

    function calculateTotal() {
        let total = 0;
        const checks = document.querySelectorAll('.check-custom:checked');
        checks.forEach(chk => {
            const p = parseFloat(chk.getAttribute('data-price'));
            const c = parseFloat(chk.getAttribute('data-count'));
            total += (p * c);
        });
        document.getElementById('totalDisplay').innerText = total.toLocaleString('uz-UZ') + " so'm";
    }

    // MICRO DONUT CHART SCRIPT
    const ctx = document.getElementById('miniChart').getContext('2d');
    const labels = [];
    const data = [];
    <% mevalar.forEach(m => { %>
        labels.push('<%= m.nomi %>');
        data.push(<%= m.soni %>);
    <% }) %>

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: ['#ff4757', '#ffa502', '#2ed573', '#1e90ff', '#9b5de5', '#f15bb5', '#10b981'],
                borderWidth: 1,
                borderColor: '#ffffff'
            }]
        },
        options: {
            cutout: '70%',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } } // Ortiqcha tooltip o'chirildi
        }
    });
</script>

</body>
</html>