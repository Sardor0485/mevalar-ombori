<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <title>Ombor Boshqaruvi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light p-3">
    <div class="container" style="max-width: 600px;">
        <h4 class="text-center my-3"><i class="bi bi-box-seam"></i> Ombor Ombori</h4>
        
        <div class="card shadow-sm mb-4 p-3">
            <canvas id="myChart" style="max-height: 200px;"></canvas>
        </div>

        <form action="/meva/qoshish" method="POST" class="input-group mb-4 shadow-sm">
            <input type="text" name="nomi" class="form-control" placeholder="Meva nomi" required>
            <input type="number" name="soni" class="form-control" placeholder="Soni" required>
            <button class="btn btn-success"><i class="bi bi-plus-lg"></i></button>
        </form>

        <div class="table-responsive bg-white rounded shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr><th>Nomi</th><th>Soni</th><th>Amallar</th></tr>
                </thead>
                <tbody>
                    <% mevalar.forEach((m) => { %>
                    <tr>
                        <td class="fw-bold"><%= m.nomi %></td>
                        <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>" class="form-control form-control-sm" style="width: 80px;"></td>
                        <td>
                            <button onclick="save('<%= m.id %>')" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i></button>
                            <a href="/meva/ochirish/<%= m.id %>" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        new Chart(document.getElementById('myChart'), { 
            type: 'doughnut', 
            data: { 
                labels: <%- JSON.stringify(mevalar.map(m => m.nomi)) %>, 
                datasets: [{ data: <%- JSON.stringify(mevalar.map(m => m.soni)) %>, backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0'] }] 
            },
            options: { plugins: { legend: { display: false } } }
        });

        function save(id) {
            const soni = document.getElementById('soni-'+id).value;
            fetch('/meva/tahrirlash/'+id, { 
                method: 'POST', headers: {'Content-Type': 'application/json'}, 
                body: JSON.stringify({ soni }) 
            }).then(() => location.reload());
        }
    </script>
</body>
</html>