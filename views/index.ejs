<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light p-3">
<div class="container" style="max-width: 600px;">
    <h3 class="text-center fw-bold text-primary">📦 Ombor Holati</h3>
    
    <div class="card p-3 shadow-sm mb-4"><canvas id="myChart" height="150"></canvas></div>
    
    <div class="alert alert-success text-center">
        Jami qiymat: <%= mevalar.reduce((a, b) => a + (b.soni * b.narxi), 0).toLocaleString() %> so'm
    </div>

    <form action="/meva/qoshish" method="POST" class="row g-2 mb-4">
        <div class="col-4"><input type="text" name="nomi" class="form-control" placeholder="Nomi" required></div>
        <div class="col-3"><input type="number" name="soni" class="form-control" placeholder="Soni" required></div>
        <div class="col-3"><input type="number" name="narxi" class="form-control" placeholder="Narxi" required></div>
        <div class="col-2"><button class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i></button></div>
    </form>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr>
            </thead>
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="s-<%= m.id %>" class="form-control form-control-sm" style="width: 70px;"></td>
                    <td><input type="number" value="<%= m.narxi %>" id="n-<%= m.id %>" class="form-control form-control-sm" style="width: 80px;"></td>
                    <td>
                        <button onclick="save('<%= m.id %>')" class="btn btn-outline-success btn-sm"><i class="bi bi-check2"></i></button>
                        <a href="/meva/ochirish/<%= m.id %>" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<script>
    new Chart(document.getElementById('myChart'), {
        type: 'bar',
        data: { labels: <%- JSON.stringify(mevalar.map(m => m.nomi)) %>, datasets: [{ label: 'Soni', data: <%- JSON.stringify(mevalar.map(m => m.soni)) %>, backgroundColor: '#0d6efd' }] }
    });
    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ soni: document.getElementById('s-'+id).value, narxi: document.getElementById('n-'+id).value }) })
        .then(() => location.reload());
    }
</script>
</body>
</html>