<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Boshqaruvi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .excel-input { width: 80px; text-align: center; border: 1px solid #ced4da; border-radius: 4px; padding: 5px; }
    </style>
</head>
<body class="bg-light p-3">

<div class="container" style="max-width: 600px;">
    <h3 class="text-center mb-4">🍎 Ombor Ombori</h3>
    
    <div class="card shadow-sm mb-4 p-3">
        <canvas id="myChart" style="max-height: 250px;"></canvas>
    </div>

    <div class="table-responsive bg-white p-2 rounded shadow-sm">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr>
            </thead>
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td class="fw-bold"><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>" class="excel-input"></td>
                    <td><input type="number" value="<%= m.narxi %>" id="narxi-<%= m.id %>" class="excel-input"></td>
                    <td>
                        <button onclick="save('<%= m.id %>')" class="btn btn-primary btn-sm">Saqlash</button>
                        <a href="/meva/ochirish/<%= m.id %>" class="btn btn-danger btn-sm">O'chirish</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    // Grafik
    const labels = <%- JSON.stringify(mevalar.map(m => m.nomi)) %>;
    const values = <%- JSON.stringify(mevalar.map(m => m.soni)) %>;
    new Chart(document.getElementById('myChart'), { 
        type: 'doughnut', 
        data: { labels, datasets: [{ data: values, backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF'] }] }
    });

    // Saqlash funksiyasi
    function save(id) {
        const soni = document.getElementById('soni-'+id).value;
        const narxi = document.getElementById('narxi-'+id).value;
        fetch('/meva/tahrirlash/'+id, { 
            method: 'POST', 
            headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ soni, narxi }) 
        })
        .then(res => res.json())
        .then(data => { if(data.success) location.reload(); });
    }
</script>
</body>
</html>