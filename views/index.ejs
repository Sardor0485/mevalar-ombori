<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #f0f2f5; font-size: 1.1rem; }
        .chart-container { width: 150px; height: 150px; margin: 0 auto; }
        .table { background: white; border-radius: 15px; overflow: hidden; }
        .excel-input { width: 80px; border: 2px solid #e0e0e0; border-radius: 8px; text-align: center; font-weight: bold; }
        .btn-action { font-size: 1.2rem; padding: 5px 12px; }
        h1 { color: #4a148c; font-weight: 800; }
    </style>
</head>
<body class="p-4">

    <div class="container">
        <h1 class="text-center mb-4">📦 Ombor Holati</h1>
        
        <!-- Chart 150x150 -->
        <div class="card mb-4 p-3 shadow-sm border-0">
            <div class="chart-container">
                <canvas id="myChart"></canvas>
            </div>
        </div>

        <!-- CRUD Form -->
        <div class="card p-4 shadow-sm border-0 mb-4">
            <form action="/meva/qoshish" method="POST" class="row g-2">
                <div class="col-md-4"><input name="nomi" class="form-control form-control-lg" placeholder="Meva nomi" required></div>
                <div class="col-md-3"><input type="number" name="soni" class="form-control form-control-lg" placeholder="Soni" required></div>
                <div class="col-md-3"><input type="number" name="narxi" class="form-control form-control-lg" placeholder="Narxi" required></div>
                <div class="col-md-2"><button class="btn btn-primary btn-lg w-100"><i class="bi bi-plus-lg"></i></button></div>
            </form>
        </div>

        <!-- Table -->
        <table class="table table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr><th>Meva</th><th>Soni</th><th>Narxi</th><th>Amallar</th></tr>
            </thead>
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td class="fw-bold text-primary"><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>" class="excel-input"></td>
                    <td><input type="number" value="<%= m.narxi %>" id="narxi-<%= m.id %>" class="excel-input"></td>
                    <td>
                        <button onclick="save('<%= m.id %>')" class="btn btn-success btn-action"><i class="bi bi-floppy"></i></button>
                        <a href="/meva/ochirish/<%= m.id %>" class="btn btn-danger btn-action"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

<script>
    new Chart(document.getElementById('myChart'), { 
        type: 'doughnut', 
        data: { 
            labels: [<%- mevalar.map(m => `'${m.nomi}'`).join(',') %>], 
            datasets: [{ 
                data: [<%- mevalar.map(m => m.soni).join(',') %>], 
                backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF'] 
            }] 
        },
        options: { maintainAspectRatio: false }
    });

    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ soni: document.getElementById('soni-'+id).value, narxi: document.getElementById('narxi-'+id).value })
        }).then(() => location.reload());
    }
</script>
</body>
</html>