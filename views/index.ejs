<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Boshqaruvi</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Excel Export uchun -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        body { background-color: #f4f7f6; font-family: 'Segoe UI', sans-serif; }
        .glass-card { background: #ffffff; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        .transparent-input { border: none; background: transparent; width: 60px; outline: none; font-weight: bold; }
        .table > :not(caption) > * > * { padding: 1rem 0.5rem; }
    </style>
</head>
<body class="p-3">

<div class="container" style="max-width: 700px;">
    <h3 class="text-center mb-4"><i class="bi bi-shop"></i> Ombor Ombori</h3>

    <!-- Qidiruv va Excel tugmasi -->
    <div class="d-flex gap-2 mb-3">
        <input type="text" id="searchInput" class="form-control" placeholder="🔍 Meva nomi bo'yicha qidirish...">
        <button class="btn btn-success" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i></button>
    </div>

    <!-- Jadval -->
    <div class="glass-card p-3">
        <table class="table table-hover align-middle mb-0" id="mevalarTable">
            <thead class="table-light">
                <tr>
                    <th><input type="checkbox" id="selectAll" class="form-check-input"></th>
                    <th>Nomi</th>
                    <th>Soni</th>
                    <th>Narxi (so'm)</th>
                    <th>Amal</th>
                </tr>
            </thead>
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr class="item-row">
                    <td><input type="checkbox" class="row-check form-check-input" data-sum="<%= m.soni * m.narxi %>"></td>
                    <td class="fw-bold text-secondary"><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" class="transparent-input text-primary" id="soni-<%= m.id %>" onchange="save('<%= m.id %>')"></td>
                    <td><%= m.narxi.toLocaleString() %></td>
                    <td>
                        <a href="/meva/ochirish/<%= m.id %>" class="text-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <div class="mt-3 p-3 bg-light rounded d-flex justify-content-between align-items-center">
            <span class="fw-bold text-muted">Jami tanlangan:</span>
            <span class="fs-4 fw-bold text-primary" id="totalSum">0</span> <span class="text-primary">so'm</span>
        </div>
    </div>
</div>

<script>
    // Qidiruv funksiyasi
    document.getElementById('searchInput').onkeyup = function() {
        let val = this.value.toLowerCase();
        document.querySelectorAll('.item-row').forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
        });
    };

    // Checkbox orqali summa hisoblash
    document.querySelectorAll('.row-check').forEach(chk => {
        chk.onchange = calculateSum;
    });

    document.getElementById('selectAll').onchange = function() {
        document.querySelectorAll('.row-check').forEach(c => c.checked = this.checked);
        calculateSum();
    };

    function calculateSum() {
        let sum = 0;
        document.querySelectorAll('.row-check:checked').forEach(c => {
            sum += parseInt(c.dataset.sum || 0);
        });
        document.getElementById('totalSum').innerText = sum.toLocaleString();
    }

    // Excelga eksport
    function exportExcel() {
        let wb = XLSX.utils.table_to_book(document.getElementById('mevalarTable'));
        XLSX.writeFile(wb, "Ombor_Hisoboti.xlsx");
    }

    // Tahrirlash (Soni o'zgarganda avtomatik saqlash)
    function save(id) {
        const soni = document.getElementById('soni-'+id).value;
        fetch('/meva/tahrirlash/'+id, { 
            method: 'POST', 
            headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ soni }) 
        }).then(() => location.reload());
    }
</script>
</body>
</html>