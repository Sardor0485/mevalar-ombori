<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ixcham Ombor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: sans-serif; font-size: 14px; color: #1e293b; background: #f1f5f9; }
        .card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; }
        input, button { font-size: 14px !important; }
    </style>
</head>
<body class="p-4">

<div class="max-w-5xl mx-auto">
    <form action="/meva/qoshish" method="POST" class="card p-4 mb-4 flex gap-2 flex-wrap shadow-sm">
        <input type="text" name="nomi" placeholder="Nomi" class="border p-2 rounded flex-1 min-w-[120px]" required>
        <input type="number" name="narxi" placeholder="Narx" class="border p-2 rounded w-20" required>
        <input type="number" name="soni" placeholder="Soni" class="border p-2 rounded w-20" required>
        <button class="bg-indigo-600 text-white px-4 py-2 rounded">Qo'shish</button>
    </form>

    <div class="grid md:grid-cols-3 gap-4">
        <div class="card p-4 md:col-span-2 shadow-sm">
            <canvas id="mevaChart" height="80"></canvas>
        </div>
        <div class="card p-4 shadow-sm flex flex-col justify-center items-center">
            <span class="text-gray-500 uppercase text-[10px] font-bold">Jami Qiymat</span>
            <div id="totalSum" class="text-2xl font-bold text-indigo-700">0</div>
        </div>
    </div>

    <div class="card p-4 mt-4 shadow-sm overflow-x-auto">
        <table class="w-full text-left" id="mevaTable">
            <thead><tr class="text-gray-400 text-[10px] uppercase">
                <th class="p-2">Tanlash</th><th>Nomi</th><th>Narx</th><th>Soni</th><th>Amallar</th>
            </tr></thead>
            <tbody>
                <% mevalar.forEach(m => { %>
                <tr class="border-t text-sm">
                    <td class="p-2"><input type="checkbox" class="rowCheckbox" data-price="<%= m.narxi %>" data-count="<%= m.soni %>"></td>
                    <td class="p-2 font-medium"><%= m.nomi %></td>
                    <td class="p-2"><%= m.narxi %></td>
                    <td class="p-2"><%= m.soni %></td>
                    <td class="p-2 flex gap-1">
                        <button onclick="editMeva('<%= m.id %>')" class="text-blue-600 hover:underline">Edit</button>
                        <a href="/meva/ochirish/<%= m.id %>" class="text-red-600 hover:underline">Del</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    new Chart(document.getElementById('mevaChart'), {
        type: 'bar',
        data: {
            labels: <%- JSON.stringify(mevalar.map(m => m.nomi)) %>,
            datasets: [{ label: 'Narx', data: <%- JSON.stringify(mevalar.map(m => m.narxi)) %>, backgroundColor: '#4f46e5' }]
        },
        options: { responsive: true, plugins: { legend: { display: false } } }
    });

    // Summa funksiyasi
    document.querySelectorAll('.rowCheckbox').forEach(cb => {
        cb.addEventListener('change', () => {
            let total = 0;
            document.querySelectorAll('.rowCheckbox:checked').forEach(c => {
                total += (c.dataset.price * c.dataset.count);
            });
            document.getElementById('totalSum').innerText = total.toLocaleString();
        });
    });

    function editMeva(id) {
        const soni = prompt("Yangi soni:");
        const narxi = prompt("Yangi narxi:");
        if (soni && narxi) {
            fetch(`/meva/tahrirlash/${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ soni, narxi }) }).then(() => location.reload());
        }
    }
</script>
</body>
</html>