<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meva Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .hover-card:hover { transform: translateY(-5px); transition: 0.3s; }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 min-h-screen p-4 md:p-10">

    <div class="max-w-5xl mx-auto">
        <h1 class="text-4xl font-black text-white mb-8 text-center drop-shadow-lg">🍎 Meva Ombori Pro</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <form action="/meva/qoshish" method="POST" class="glass p-6 rounded-3xl shadow-2xl">
                <h2 class="text-xl font-bold mb-4 text-gray-700">➕ Yangi mahsulot</h2>
                <input type="text" name="nomi" placeholder="Nomi" class="w-full p-3 mb-3 border-2 rounded-xl focus:border-purple-500 outline-none transition" required>
                <div class="flex gap-2">
                    <input type="number" name="narxi" placeholder="Narxi" class="w-full p-3 border-2 rounded-xl outline-none" required>
                    <input type="number" name="soni" placeholder="Soni" class="w-full p-3 border-2 rounded-xl outline-none" required>
                </div>
                <button class="w-full mt-4 bg-purple-600 text-white font-bold py-3 rounded-xl hover:bg-purple-700 active:scale-95 transition">Saqlash</button>
            </form>

            <div class="glass p-6 rounded-3xl shadow-2xl">
                <canvas id="mevaChart"></canvas>
            </div>
        </div>

        <div class="glass p-6 rounded-3xl shadow-2xl mt-8 overflow-hidden">
            <table class="w-full text-left">
                <thead><tr class="text-gray-400 uppercase text-sm"><th class="p-4">Nomi</th><th class="p-4">Narxi</th><th class="p-4">Soni</th></tr></thead>
                <tbody>
                    <% mevalar.forEach(m => { %>
                    <tr class="border-t hover:bg-purple-50 transition cursor-pointer hover-card">
                        <td class="p-4 font-bold text-gray-800"><%= m.nomi %></td>
                        <td class="p-4 text-green-600 font-mono"><%= m.narxi %> so'm</td>
                        <td class="p-4 text-purple-600 font-bold"><%= m.soni %> dona</td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Chart.js uchun ma'lumotlar
        const ctx = document.getElementById('mevaChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: <%- JSON.stringify(mevalar.map(m => m.nomi)) %>,
                datasets: [{
                    label: 'Meva Soni',
                    data: <%- JSON.stringify(mevalar.map(m => m.soni)) %>,
                    backgroundColor: '#8b5cf6'
                }]
            },
            options: { responsive: true, animation: { duration: 2000 } }
        });
    </script>
</body>
</html>