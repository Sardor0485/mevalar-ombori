<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background: #f4f7f6; font-size: 15px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.07); }
        .table-responsive { overflow-x: auto; }
        .btn-action { padding: 8px 12px; font-size: 18px; }
        .form-control-sm { height: 40px; font-size: 16px; }
        
        @media (max-width: 576px) {
            .container { padding-left: 10px; padding-right: 10px; }
            h5 { font-size: 1.1rem; }
        }
    </style>
</head>
<body class="bg-light">

<div class="container py-3">
    <div class="card p-3 mb-3 text-center">
        <canvas id="myChart" style="max-height: 150px;"></canvas>
        <div id="totalDisplay" class="h5 fw-bold text-success mt-2">Jami: 0 so'm</div>
    </div>

    <div class="card p-3 mb-3">
        <button class="btn btn-primary w-100" onclick="document.getElementById('addForm').classList.toggle('d-none')">
            + Mahsulot qo'shish
        </button>
        <form id="addForm" action="/meva/qoshish" method="POST" class="d-none mt-3">
            <input type="text" name="nomi" class="form-control mb-2" placeholder="Mahsulot nomi" required>
            <input type="number" name="soni" inputmode="decimal" class="form-control mb-2" placeholder="Soni" required>
            <input type="number" name="narxi" inputmode="decimal" class="form-control mb-2" placeholder="Narxi" required>
            <button type="submit" class="btn btn-success w-100">Saqlash</button>
        </form>
    </div>

    <div class="card p-2">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr><th>#</th><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Act</th></tr>
                </thead>
                <tbody>
                    <% mevalar.forEach((meva) => { %>
                    <form id="form_<%= meva.id %>" action="/meva/tahrirlash/<%= meva.id %>" method="POST" 
                          onsubmit="return confirm('O\'zgarishlarni saqlashni tasdiqlaysizmi?')"></form>
                    
                    <tr>
                        <td><input type="checkbox" class="meva-check" data-price="<%= meva.narxi %>" data-count="<%= meva.soni %>" onchange="calculateTotal()"></td>
                        <td><%= meva.nomi %></td>
                        <td><input type="number" name="soni" inputmode="decimal" value="<%= meva.soni %>" form="form_<%= meva.id %>" class="form-control form-control-sm" style="width: 70px;"></td>
                        <td><input type="number" name="narxi" inputmode="decimal" value="<%= meva.narxi %>" form="form_<%= meva.id %>" class="form-control form-control-sm" style="width: 80px;"></td>
                        <td>
                            <button type="submit" form="form_<%= meva.id %>" class="btn btn-outline-primary btn-action">💾</button>
                            <a href="/meva/ochirish/<%= meva.id %>" class="btn btn-outline-danger btn-action" 
                               onclick="return confirm('Rostdan ham o\'chirmoqchimisiz?')">🗑️</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Chart.js sozlamalari
    const ctx = document.getElementById('myChart').getContext('2d');
    new Chart(ctx, { 
        type: 'doughnut', 
        data: { 
            labels: [<% mevalar.forEach(m => { %> '<%= m.nomi %>', <% }) %>], 
            datasets: [{ 
                data: [<% mevalar.forEach(m => { %> <%= m.soni %>, <% }) %>], 
                backgroundColor: ['#dc3545', '#fd7e14', '#198754', '#0d6efd', '#6f42c1'] 
            }] 
        }, 
        options: { plugins: { legend: { display: false } }, responsive: true, maintainAspectRatio: false } 
    });

    // Jami summani hisoblash
    function calculateTotal() {
        let total = 0;
        document.querySelectorAll('.meva-check:checked').forEach(chk => {
            total += (Number(chk.dataset.price) * Number(chk.dataset.count));
        });
        document.getElementById('totalDisplay').innerText = "Jami: " + total.toLocaleString() + " so'm";
    }
</script>
</body>
</html>