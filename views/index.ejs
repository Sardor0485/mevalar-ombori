<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .table-wrapper { max-height: 300px; overflow: auto; border: 1px solid #dee2e6; border-radius: 8px; }
        .excel-input { width: 60px; border: none; background: #fdfdfd; text-align: center; }
        .alert-row { background-color: #ffdada !important; }
    </style>
</head>
<body class="bg-light p-2">
    <div class="card mb-3 p-2"><canvas id="myChart" style="max-height: 120px;"></canvas></div>

    <div class="card p-2">
        <form action="/meva/qoshish" method="POST" class="row g-1 mb-3">
            <div class="col-4"><input name="nomi" class="form-control form-control-sm" placeholder="Meva" required></div>
            <div class="col-3"><input type="number" name="soni" class="form-control form-control-sm" placeholder="Soni" required></div>
            <div class="col-3"><input type="number" name="narxi" class="form-control form-control-sm" placeholder="Narx" required></div>
            <div class="col-2"><button class="btn btn-sm btn-success w-100">➕</button></div>
        </form>

        <div class="table-wrapper">
            <table class="table table-sm table-hover" id="omborTable">
                <thead><tr><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr></thead>
                <tbody>
                    <% mevalar.forEach((m) => { %>
                    <tr class="<%= m.soni < 5 ? 'alert-row' : '' %>">
                        <td><%= m.nomi %></td>
                        <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>" class="excel-input"></td>
                        <td><input type="number" value="<%= m.narxi %>" id="narxi-<%= m.id %>" class="excel-input"></td>
                        <td>
                            <button onclick="save('<%= m.id %>')" class="btn btn-sm btn-primary">💾</button>
                            <a href="/meva/ochirish/<%= m.id %>" class="btn btn-sm btn-danger">❌</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

<script>
    const ctx = document.getElementById('myChart');
    new Chart(ctx, { type: 'doughnut', data: { labels: [<%- mevalar.map(m => `'${m.nomi}'`).join(',') %>], datasets: [{ data: [<%- mevalar.map(m => m.soni).join(',') %>], backgroundColor: ['#0d6efd', '#198754', '#dc3545', '#ffc107'] }] } });

    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ soni: document.getElementById('soni-'+id).value, narxi: document.getElementById('narxi-'+id).value })
        }).then(() => location.reload());
    }
</script>
</body>
</html>