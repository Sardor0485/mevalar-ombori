<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Boshqaruvi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
</head>
<body class="bg-gray-100 p-4 md:p-8">

<div class="max-w-6xl mx-auto bg-white p-6 rounded-2xl shadow-xl">
    <h1 class="text-2xl font-bold mb-6">📦 Ombor Boshqaruvi</h1>

    <div class="flex flex-wrap gap-4 mb-6">
        <input type="text" id="searchInput" placeholder="🔍 Qidirish..." class="border p-2 rounded-lg flex-1">
        <button onclick="exportToExcel()" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">Excel Export</button>
        <div class="bg-purple-100 px-4 py-2 rounded-lg font-bold">Jami: <span id="totalSum">0</span> so'm</div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full border-collapse" id="mevaTable">
            <thead>
                <tr class="bg-gray-200">
                    <th class="p-3"><input type="checkbox" id="selectAll"></th>
                    <th class="p-3">Nomi</th>
                    <th class="p-3">Narxi</th>
                    <th class="p-3">Soni</th>
                    <th class="p-3">Jami</th>
                </tr>
            </thead>
            <tbody>
                <% mevalar.forEach(m => { %>
                <tr class="border-b hover:bg-gray-50">
                    <td class="p-3 text-center"><input type="checkbox" class="rowCheckbox" data-price="<%= m.narxi %>" data-count="<%= m.soni %>"></td>
                    <td class="p-3"><%= m.nomi %></td>
                    <td class="p-3"><%= m.narxi %></td>
                    <td class="p-3"><%= m.soni %></td>
                    <td class="p-3"><%= m.narxi * m.soni %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    // Qidiruv funksiyasi
    document.getElementById('searchInput').addEventListener('keyup', function() {
        const val = this.value.toLowerCase();
        document.querySelectorAll('#mevaTable tbody tr').forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
        });
    });

    // Tanlanganlar summasini hisoblash
    const checkboxes = document.querySelectorAll('.rowCheckbox');
    const totalSum = document.getElementById('totalSum');
    
    checkboxes.forEach(cb => {
        cb.addEventListener('change', () => {
            let sum = 0;
            document.querySelectorAll('.rowCheckbox:checked').forEach(c => {
                sum += (c.dataset.price * c.dataset.count);
            });
            totalSum.innerText = sum.toLocaleString();
        });
    });

    // Excelga eksport
    function exportToExcel() {
        const wb = XLSX.utils.table_to_book(document.getElementById('mevaTable'));
        XLSX.writeFile(wb, "Ombor_Hisoboti.xlsx");
    }
</script>
</body>
</html>