<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mevalar Ombori</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #f9fbf9; /* Mayin tabiiy och yashil-oq fon */
            color: #2d3748;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 850px;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
        }

        h1 {
            font-size: 22px;
            font-weight: 600;
            margin: 0;
            color: #2f855a; /* Toza o'rmon yashili */
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logout-btn {
            font-size: 13px;
            color: #718096;
            text-decoration: none;
            padding: 6px 14px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            color: #c53030; /* Qulupnay qizili */
            border-color: #feb2b2;
            background: #fff5f5;
        }

        /* Forma kartasi */
        .form-card {
            background: white;
            padding: 20px 25px;
            border-radius: 12px;
            border: 1px solid #edf2f7;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01);
            margin-bottom: 30px;
        }

        .form-card h3 {
            margin: 0 0 15px 0;
            font-size: 13px;
            font-weight: 600;
            color: #4a5568;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .form-group input {
            border: 1px solid #cbd5e0;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 14px;
            flex: 1;
            min-width: 160px;
            outline: none;
            transition: all 0.2s;
            background: #f7fafc;
        }

        .form-group input:focus {
            border-color: #48bb78; /* Meva yashili */
            background: white;
            box-shadow: 0 0 0 3px rgba(72, 187, 120, 0.1);
        }

        .btn-add {
            background: #38a169;
            color: white;
            border: none;
            padding: 10px 22px;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            font-weight: 500;
            transition: background 0.2s;
        }

        .btn-add:hover {
            background: #2f855a;
        }

        /* Jadval paneli */
        .table-wrapper {
            background: white;
            border-radius: 12px;
            border: 1px solid #edf2f7;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #f7fafc;
            color: #4a5568;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            padding: 14px 20px;
            border-bottom: 1px solid #edf2f7;
            letter-spacing: 0.5px;
            text-align: left;
        }

        td {
            padding: 14px 20px;
            border-bottom: 1px solid #f7fafc;
            font-size: 14px;
            vertical-align: middle;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .meva-title {
            font-weight: 500;
            color: #2d3748;
            font-size: 15px;
        }

        /* Inline tahrirlash formasi */
        .edit-form {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .edit-form input {
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 6px 10px;
            width: 90px;
            font-size: 13px;
            outline: none;
            transition: border-color 0.2s;
        }

        .edit-form input:focus {
            border-color: #48bb78;
        }

        .btn-update {
            background: white;
            border: 1px solid #cbd5e0;
            color: #4a5568;
            padding: 5px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-update:hover {
            background: #f0fff4;
            border-color: #38a169;
            color: #276749;
        }

        /* O'chirish havolasi */
        .btn-delete {
            color: #a0aec0;
            text-decoration: none;
            font-size: 13px;
            transition: color 0.2s;
        }

        .btn-delete:hover {
            color: #e53e3e;
        }

        .no-data {
            text-align: center;
            color: #718096;
            padding: 40px !important;
            font-size: 14px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>🍓 Mevalar Ombori Paneli</h1>
        <a href="/logout" class="logout-btn">Chiqish 🚪</a>
    </div>

    <div class="form-card">
        <h3>🍋 Yangi mahsulot kiritish</h3>
        <form action="/meva/qoshish" method="POST" class="form-group">
            <input type="text" name="nomi" placeholder="Meva nomi (Masalan: Behi)" required>
            <input type="number" name="soni" placeholder="Soni (ta)" min="0" required>
            <input type="number" name="narxi" placeholder="Narxi (so'm)" min="0" required>
            <button type="submit" class="btn-add">Omborga qo'shish</button>
        </form>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th>Nomi</th>
                    <th>Miqdori va narxi (Tahrirlash)</th>
                    <th style="width: 90px; text-align: right;">Amal</th>
                </tr>
            </thead>
            <tbody>
                <% if (mevalar && mevalar.length > 0) { %>
                    <% mevalar.forEach(meva => { %>
                        <tr>
                            <td style="color: #a0aec0;">#<%= meva.id %></td>
                            <td><span class="meva-title">🍏 <%= meva.nomi %></span></td>
                            <td>
                                <form action="/meva/tahrirlash/<%= meva.id %>" method="POST" class="edit-form">
                                    <input type="number" name="soni" value="<%= meva.soni %>" required> <span style="color: #a0aec0; font-size: 13px;">ta</span>
                                    <input type="number" name="narxi" value="<%= meva.narxi %>" required> <span style="color: #a0aec0; font-size: 13px;">so'm</span>
                                    <button type="submit" class="btn-update">Saqlash</button>
                                </form>
                            </td>
                            <td style="text-align: right;">
                                <a href="/meva/ochirish/<%= meva.id %>" class="btn-delete" onclick="return confirm('Haqiqatdan ham o\'chirilsinmi?')">O'chirish</a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="no-data">📦 Omborda mevalar tugadi. Yuqoridan yangi meva qo'shing.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

</body>
</html>