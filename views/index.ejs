<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fruit CRM Pro — Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
            margin: 0;
            padding: 20px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 950px;
        }

        /* HEADER */
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            margin-bottom: 20px;
        }

        .logo { font-size: 20px; font-weight: 700; color: #166534; }

        .btn-add {
            background: #166534; color: white; border: none; padding: 8px 16px;
            border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px;
        }

        /* DASHBOARD SECTION */
        .dashboard-top {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        /* Grafik kartasi */
        .chart-card {
            background: white; border-radius: 16px; border: 1px solid #e2e8f0;
            padding: 20px; display: flex; flex-direction: column; align-items: center;
        }

        .chart-card h4 { margin: 0 0 15px 0; font-size: 14px; color: #64748b; }

        /* Jami Summa kartasi */
        .summary-card {
            background: white; border-radius: 16px; border: 1px solid #e2e8f0;
            padding: 25px; display: flex; flex-direction: column; justify-content: center;
            text-align: center;
        }

        .summary-card span { font-size: 14px; color: #64748b; font-weight: 500; }
        .summary-card h2 { margin: 10px 0 0 0; font-size: 32px; color: #166534; }

        /* SEARCH BAR */
        .search-container {
            margin-bottom: 15px; position: relative;
        }

        .search-input {
            width: 100%; padding: 12px 15px 12px 40px; border-radius: 12px;
            border: 1px solid #e2e8f0; outline: none; font-size: 14px; box-sizing: border-box;
        }

        .search-input:focus { border-color: #166534; }

        /* TABLE SECTION */
        .table-wrapper {
            background: white; border-radius: 16px; border: 1px solid #e2e8f0;
            overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        
        th { 
            background: #f8fafc; color: #64748b; font-weight: 600; 
            padding: 12px 15px; text-align: left; border-bottom: 1px solid #f1f5f9;
        }

        td { padding: 8px 15px; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
        tr:hover { background-color: #fcfdfc; }

        /* RAMKASIZ INPUTLAR */
        .edit-form { display: flex; align-items: center; gap: 8px; }
        
        .compact-input {
            border: 1px solid transparent; background: transparent;
            padding: 5px; font-size: 14px; width: 70px; outline: none;
            transition: all 0.2s; border-radius: 4px;
        }

        .compact-input:focus { border-color: #166534; background: #f0fdf4; }

        /* RADIO/CHECKBOX STYLE */
        .check-input {
            width: 18px; height: 18px; cursor: pointer; accent-color: #166534;
        }

        .btn-icon {
            background: none; border: none; cursor: pointer; color: #94a3b8;
            padding: 5px; transition: color 0.2s;
        }

        .btn-icon:hover { color: #166534; }
        .btn-delete:hover { color: #ef4444; }

        /* FORMA */
        .form-overlay {
            display: none; background: white; border: 1px solid #e2e8f0;
            padding: 20px; border-radius: 16px; margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .dashboard-top { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="container">
    
    <div class="admin-header">
        <div class="logo">Fruit Pro Dashboard</div>
        <div style="display: flex; gap: 10px;">
            <button class="btn-add" onclick="toggleForm()">+ Mahsulot</button>
            <a href="/logout" style="text-decoration: none; font-size: 13px; color: #ef4444; font-weight: 600; padding: 8px;">Chiqish</a>
        </div>
    </div>

    <div class="form-overlay" id="addForm">
        <form action="/meva/qoshish" method="POST" style="display: flex; gap: 10px; flex-wrap: wrap;">
            <input type="text" name="nomi" placeholder="Meva nomi" style="flex: 1; padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0;" required>
            <input type="number" name="soni" placeholder="Soni" style="width: 80px; padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0;" required>
            <input type="number" name="narxi" placeholder="Narxi" style="width: 120px; padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0;" required>
            <button type="submit" class="btn-add">Saqlash</button>
        </form>
    </div>

    <div class="dashboard-top">
        <div class="chart-card">
            <h4>Zaxira ulushi (%)</h4>
            <canvas id="fruitChart" width="180" height="180"></canvas>
        </div>
        <div class="summary-card">
            <span>Tanlangan mahsulotlar jami:</span>
            <h2 id="totalDisplay">0 so'm</h2>
        </div>
    </div>

    <div class="search-container">
        <span style="position: absolute; left: 15px; top: 12px; color: #94a3b8;">🔍</span>
        <input type="text" id="searchInput" class="search-input" placeholder="Mahsulotlarni izlash..." onkeyup="liveSearch()">
    </div>

    <div class="table-wrapper">
        <table id="mevaTable">
            <thead>
                <tr>
                    <th style="width: 30px;"></th>
                    <th style="width: 40px;">ID</th>
                    <th>Mahsulot</th>
                    <th>Zaxira</th>
                    <th>Narx</th>
                    <th style="width: 80px; text-align: right;">Amal</th>
                </tr>
            </thead>
            <tbody>
                <% if (mevalar && mevalar.length > 0) { %>
                    <% mevalar.forEach((meva) => { %>
                        <tr class="meva-row">
                            <td>
                                <input type="checkbox" class="check-input" 
                                       data-price="<%= meva.narxi %>" 
                                       data-count="<%= meva.soni %>"
                                       onchange="calculateTotal()">
                            </td>
                            <td style="color: #94a3b8;">#<%= meva.id %></td>
                            <td class="meva-name" style="font-weight: 600;"><%= meva.nomi %></td>
                            <form action="/meva/tahrirlash/<%= meva.id %>" method="POST">
                                <td>
                                    <input type="number" name="soni" class="compact-input" value="<%= meva.soni %>" required>
                                </td>
                                <td>
                                    <input type="number" name="narxi" class="compact-input" style="width: 100px;" value="<%= meva.narxi %>" required>
                                </td>
                                <td style="text-align: right;">
                                    <button type="submit" class="btn-icon" title="Saqlash">💾</button>
                                    <a href="/meva/ochirish/<%= meva.id %>" class="btn-icon btn-delete" onclick="return confirm('O\'chirilsinmi?')">🗑️</a>
                                </td>
                            </form>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" style="text-align: center; padding: 30px; color: #94a3b8;">Ma'lumotlar mavjud emas.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    // FORM TOGGLE
    function toggleForm() {
        const f = document.getElementById('addForm');
        f.style.display = (f.style.display === 'block') ? 'none' : 'block';
    }

    // SEARCH
    function liveSearch() {
        const filter = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('.meva-row');
        rows.forEach(row => {
            const name = row.querySelector('.meva-name').textContent.toLowerCase();
            row.style.display = name.includes(filter) ? "" : "none";
        });
    }

    // DINAMIK JAMI SUMMANI HISOBLASH
    function calculateTotal() {
        let total = 0;
        const checks = document.querySelectorAll('.check-input:checked');
        checks.forEach(chk => {
            const price = parseFloat(chk.getAttribute('data-price'));
            const count = parseFloat(chk.getAttribute('data-count'));
            total += (price * count);
        });
        document.getElementById('totalDisplay').innerText = total.toLocaleString('uz-UZ') + " so'm";
    }

    // DONUT CHART (Chart.js)
    const ctx = document.getElementById('fruitChart').getContext('2d');
    const labels = [];
    const data = [];
    
    <% mevalar.forEach(m => { %>
        labels.push('<%= m.nomi %>');
        data.push(<%= m.soni %>);
    <% }) %>

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: ['#166534', '#22c55e', '#86efac', '#bbf7d0', '#dcfce7'],
                borderWidth: 0,
                hoverOffset: 10
            }]
        },
        options: {
            cutout: '75%',
            plugins: {
                legend: { display: false }
            }
        }
    });
</script>

</body>
</html>