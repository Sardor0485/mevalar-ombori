<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pro Ombor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background: #f8fafc; }
        .card { background: white; border-radius: 20px; border: 1px solid #e2e8f0; }
        .btn-action { transition: 0.2s; padding: 4px 12px; border-radius: 8px; font-size: 12px; }
    </style>
</head>
<body class="p-4 md:p-10">

<div class="max-w-6xl mx-auto">
    <form action="/meva/qoshish" method="POST" class="card p-6 mb-8 flex flex-wrap gap-4 items-center">
        <input type="text" name="nomi" placeholder="Meva nomi" class="p-3 bg-slate-50 rounded-xl outline-none flex-1" required>
        <input type="number" name="narxi" placeholder="Narxi" class="p-3 bg-slate-50 rounded-xl outline-none w-32" required>
        <input type="number" name="soni" placeholder="Soni" class="p-3 bg-slate-50 rounded-xl outline-none w-32" required>
        <button class="bg-indigo-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-indigo-700">Qo'shish</button>
    </form>

    <div class="card p-6 overflow-x-auto">
        <table class="w-full text-left" id="mevaTable">
            <thead><tr class="text-slate-400 text-xs uppercase">
                <th class="p-4">Tanlash</th><th class="p-4">Nomi</th><th class="p-4">Narxi</th><th class="p-4">Soni</th><th class="p-4">Amallar</th>
            </tr></thead>
            <tbody>
                <% mevalar.forEach(m => { %>
                <tr class="border-t border-slate-50 hover:bg-slate-50">
                    <td class="p-4"><input type="checkbox" class="rowCheckbox w-5 h-5 accent-indigo-600" data-price="<%= m.narxi %>" data-count="<%= m.soni %>"></td>
                    <td class="p-4 font-medium"><%= m.nomi %></td>
                    <td class="p-4"><%= m.narxi %></td>
                    <td class="p-4"><%= m.soni %></td>
                    <td class="p-4 flex gap-2">
                        <button onclick="editMeva('<%= m.id %>')" class="bg-blue-100 text-blue-600 btn-action hover:bg-blue-200">Edit</button>
                        <a href="/meva/ochirish/<%= m.id %>" class="bg-red-100 text-red-600 btn-action hover:bg-red-200">Delete</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    function editMeva(id) {
        const soni = prompt("Yangi sonini kiriting:");
        const narxi = prompt("Yangi narxini kiriting:");
        if (soni && narxi) {
            fetch(`/meva/tahrirlash/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ soni, narxi })
            }).then(() => location.reload());
        }
    }
</script>
</body>
</html>