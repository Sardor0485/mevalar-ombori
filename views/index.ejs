<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Boshqaruvi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background: #f0f2f5; }
        .glass-card { background: white; border-radius: 20px; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
        .btn-action { transition: 0.3s; }
        .btn-action:hover { transform: scale(1.1); }
    </style>
</head>
<body class="p-3">
    <div class="container" style="max-width: 500px;">
        <h4 class="text-center mb-4 text-primary fw-bold">🍏 Ombor Tizimi</h4>
        
        <div class="glass-card p-4 mb-4">
            <form action="/meva/qoshish" method="POST" class="d-flex gap-2">
                <input type="text" name="nomi" class="form-control" placeholder="Nomi" required>
                <input type="number" name="soni" class="form-control" placeholder="Soni" required>
                <button class="btn btn-primary"><i class="bi bi-plus-lg"></i></button>
            </form>
        </div>

        <div class="glass-card p-3">
            <table class="table table-borderless align-middle">
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td class="fw-bold"><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="s-<%= m.id %>" class="form-control form-control-sm" style="width: 70px;"></td>
                    <td class="text-end">
                        <button onclick="save('<%= m.id %>')" class="btn btn-outline-success btn-sm btn-action"><i class="bi bi-pencil-square"></i></button>
                        <a href="/meva/ochirish/<%= m.id %>" class="btn btn-outline-danger btn-sm btn-action"><i class="bi bi-trash3"></i></a>
                    </td>
                </tr>
                <% }) %>
            </table>
        </div>
    </div>
<script>
    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ soni: document.getElementById('s-'+id).value }) })
        .then(() => location.reload());
    }
</script>
</body>
</html>