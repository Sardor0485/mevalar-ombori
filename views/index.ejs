<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meva Ombori</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 p-6">

    <div class="max-w-4xl mx-auto">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">🍎 Ombor Boshqaruvi</h1>

        <form action="/meva/qoshish" method="POST" class="bg-white p-6 rounded-xl shadow-sm mb-6 flex gap-4">
            <input type="text" name="nomi" placeholder="Nomi" class="border p-2 rounded w-full" required>
            <input type="number" name="narxi" placeholder="Narxi" class="border p-2 rounded w-32" required>
            <input type="number" name="soni" placeholder="Soni" class="border p-2 rounded w-32" required>
            <button class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">Qo'shish</button>
        </form>

        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-100">
                    <tr>
                        <th class="p-4">Nomi</th>
                        <th class="p-4">Narxi</th>
                        <th class="p-4">Soni</th>
                        <th class="p-4">Amallar</th>
                    </tr>
                </thead>
                <tbody>
                    <% mevalar.forEach(m => { %>
                    <tr class="border-b">
                        <td class="p-4"><%= m.nomi %></td>
                        <td class="p-4"><%= m.narxi %></td>
                        <td class="p-4"><%= m.soni %></td>
                        <td class="p-4 flex gap-2">
                            <button onclick="editMeva('<%= m.id %>')" class="text-blue-600 underline">Edit</button>
                            <a href="/meva/ochirish/<%= m.id %>" class="text-red-600 underline">Delete</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Tahrirlash funksiyasi (Prompt orqali)
        function editMeva(id) {
            const soni = prompt("Yangi sonini kiriting:");
            const narxi = prompt("Yangi narxini kiriting:");
            if (soni && narxi) {
                fetch(`/meva/tahrirlash/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ soni, narxi })
                }).then(() => location.reload());
            }
        }
    </script>
</body>
</html>