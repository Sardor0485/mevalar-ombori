<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh; padding: 20px; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
        .form-control, .transparent-input { border: 1px solid rgba(0,0,0,0.1); border-radius: 12px; }
        .transparent-input { background: transparent; width: 70px; text-align: center; font-weight: bold; }
    </style>
</head>
<body>
<div class="container" style="max-width: 600px;">
    <h3 class="text-center mb-4 fw-bold text-white shadow-sm">🍎 Ombor Nazorati</h3>
    
    <div class="glass mb-4">
        <form action="/meva/qoshish" method="POST" class="row g-2">
            <div class="col-4"><input type="text" name="nomi" class="form-control" placeholder="Nomi" required></div>
            <div class="col-3"><input type="number" name="soni" class="form-control" placeholder="Soni" required></div>
            <div class="col-3"><input type="number" name="narxi" class="form-control" placeholder="Narx" required></div>
            <div class="col-2"><button class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i></button></div>
        </form>
    </div>

    <div class="glass">
        <table class="table table-borderless align-middle" id="mevaTable">
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td><input type="checkbox" class="row-check" data-sum="<%= m.soni * m.narxi %>"></td>
                    <td class="fw-bold text-dark"><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="s-<%= m.id %>" class="transparent-input" onchange="save('<%= m.id %>')"></td>
                    <td><input type="number" value="<%= m.narxi %>" id="n-<%= m.id %>" class="transparent-input" onchange="save('<%= m.id %>')"></td>
                    <td><a href="/meva/ochirish/<%= m.id %>" class="text-danger"><i class="bi bi-trash-fill"></i></a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-3">
            <h5 class="m-0 text-dark">Jami: <span id="totalSum" class="text-primary">0</span> so'm</h5>
            <button class="btn btn-success" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i></button>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.row-check').forEach(c => c.onchange = () => {
        let sum = 0;
        document.querySelectorAll('.row-check:checked').forEach(c => sum += parseInt(c.dataset.sum));
        document.getElementById('totalSum').innerText = sum.toLocaleString();
    });

    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ soni: document.getElementById('s-'+id).value, narxi: document.getElementById('n-'+id).value }) })
        .then(() => location.reload());
    }

    function exportExcel() { XLSX.writeFile(XLSX.utils.table_to_book(document.getElementById('mevaTable')), "Ombor.xlsx"); }
</script>
</body>
</html>