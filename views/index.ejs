<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Boshqaruvi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        body { background: #f0f2f5; }
        .glass-card { background: white; border-radius: 20px; box-shadow: 0 8px 32px rgba(0,0,0,0.1); padding: 20px; }
        .transparent-input { border: none; background: transparent; width: 80px; font-weight: bold; }
    </style>
</head>
<body class="p-3">
<div class="container" style="max-width: 650px;">
    <h4 class="text-center mb-4 text-primary fw-bold">🍏 Ombor Boshqaruvi</h4>
    
    <!-- Qo'shish Formasi -->
    <div class="glass-card mb-4">
        <form action="/meva/qoshish" method="POST" class="d-flex gap-2">
            <input type="text" name="nomi" class="form-control" placeholder="Nomi" required>
            <input type="number" name="soni" class="form-control" placeholder="Soni" required>
            <input type="number" name="narxi" class="form-control" placeholder="Narxi" required>
            <button class="btn btn-primary"><i class="bi bi-plus-lg"></i></button>
        </form>
    </div>

    <!-- Jadval -->
    <div class="glass-card">
        <table class="table table-borderless align-middle" id="mevalarTable">
            <thead><tr><th><input type="checkbox" id="selectAll"></th><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr></thead>
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr class="item-row">
                    <td><input type="checkbox" class="row-check" data-sum="<%= m.soni * m.narxi %>"></td>
                    <td class="fw-bold"><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="s-<%= m.id %>" class="transparent-input"></td>
                    <td><%= m.narxi.toLocaleString() %></td>
                    <td>
                        <button onclick="save('<%= m.id %>')" class="btn btn-sm btn-outline-success"><i class="bi bi-check2"></i></button>
                        <a href="/meva/ochirish/<%= m.id %>" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <h5 class="text-muted">Jami: <span id="totalSum" class="text-primary">0</span> so'm</h5>
            <button class="btn btn-success btn-sm" onclick="exportExcel()">📥 Excel</button>
        </div>
    </div>
</div>
<script>
    // Summa hisoblash
    document.querySelectorAll('.row-check').forEach(c => c.onchange = () => {
        let sum = 0;
        document.querySelectorAll('.row-check:checked').forEach(c => sum += parseInt(c.dataset.sum));
        document.getElementById('totalSum').innerText = sum.toLocaleString();
    });

    // Saqlash
    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ soni: document.getElementById('s-'+id).value, narxi: 0 }) })
        .then(() => location.reload());
    }

    function exportExcel() { XLSX.writeFile(XLSX.utils.table_to_book(document.getElementById('mevalarTable')), "Hisobot.xlsx"); }
</script>
</body>
</html>