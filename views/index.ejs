<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        .table-wrapper { max-height: 400px; overflow: auto; border: 1px solid #dee2e6; }
        .excel-input { width: 70px; border: none; background: transparent; }
        .alert-danger-row { background-color: #ffdada !important; }
    </style>
</head>
<body class="p-3">
    <div class="card p-2 mb-3"><canvas id="myChart" style="max-height: 100px;"></canvas></div>
    <div class="card p-2">
        <input type="text" id="searchInput" class="form-control mb-2" placeholder="🔍 Qidirish..." onkeyup="filterTable()">
        <div class="table-wrapper">
            <table class="table table-sm table-hover" id="omborTable">
                <thead><tr><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr></thead>
                <tbody id="tableBody">
                    <% mevalar.forEach((m) => { %>
                    <tr id="row-<%= m.id %>" class="<%= m.soni < 5 ? 'alert-danger-row' : '' %>">
                        <td><%= m.nomi %></td>
                        <td><input type="number" id="soni-<%= m.id %>" value="<%= m.soni %>" class="excel-input"></td>
                        <td><input type="number" id="narxi-<%= m.id %>" value="<%= m.narxi %>" class="excel-input"></td>
                        <td><button onclick="save('<%= m.id %>', '<%= m.nomi %>')" class="btn btn-sm btn-primary">💾</button></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <button onclick="exportTable()" class="btn btn-success mt-2">📥 Excel</button>
    </div>

<script>
    function save(id, nomi) {
        fetch('/meva/tahrirlash/'+id, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ soni: document.getElementById('soni-'+id).value, narxi: document.getElementById('narxi-'+id).value })
        }).then(() => alert("Saqlandi!"));
    }
    function filterTable() {
        let val = document.getElementById("searchInput").value.toUpperCase();
        document.querySelectorAll("#tableBody tr").forEach(tr => tr.style.display = tr.innerText.toUpperCase().includes(val) ? "" : "none");
    }
    function exportTable() { XLSX.writeFile(XLSX.utils.table_to_book(document.getElementById('omborTable')), "Ombor.xlsx"); }
</script>
</body>
</html>