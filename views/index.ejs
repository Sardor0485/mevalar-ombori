<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mevalar Ombori</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9fafb;
            color: #1f2937;
            margin: 0;
            padding: 20px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 800px;
        }

        /* Ixcham Tepadagi Panel */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            padding: 12px 16px;
            border-radius: 8px 8px 0 0;
            border: 1px solid #d1d5db;
            border-bottom: none;
        }

        .logo-area {
            font-size: 16px;
            font-weight: 700;
            color: #107c41;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .actions-area {
            display: flex;
            gap: 8px;
        }

        /* Plyus tugmasi */
        .btn-toggle-form {
            background: #107c41;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .btn-toggle-form:hover {
            background: #0e6836;
        }

        .btn-logout {
            background: white;
            color: #4b5563;
            border: 1px solid #d1d5db;
            padding: 6px 12px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
        }

        .btn-logout:hover {
            background: #fef2f2;
            color: #dc2626;
            border-color: #fca5a5;
        }

        /* Silliq ochiluvchi forma */
        .form-container {
            background: #f9fafb;
            border: 1px solid #d1d5db;
            padding: 0px 16px;
            max-height: 0;
            overflow: hidden;
            transition: all 0.3s ease;
            opacity: 0;
        }

        .form-container.show {
            padding: 16px;
            max-height: 180px;
            opacity: 1;
            border-bottom: none;
        }

        .excel-form {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .excel-form input {
            border: 1px solid #d1d5db;
            padding: 8px 12px;
            font-size: 13px;
            border-radius: 4px;
            outline: none;
            background: white;
            flex: 1;
            min-width: 120px;
        }

        .excel-form input:focus {
            border-color: #107c41;
        }

        .btn-save-new {
            background: #107c41;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
        }

        /* Ixcham Chiziqli Jadval */
        .table-wrapper {
            background: white;
            border: 1px solid #d1d5db;
            border-radius: 0 0 8px 8px;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            min-width: 500px; /* Telefonda siqilib ketmasligi uchun majburiy kenglik */
        }

        th {
            background: #f3f4f6;
            color: #374151;
            font-weight: 600;
            padding: 8px 12px;
            border: 1px solid #d1d5db;
            text-align: left;
        }

        td {
            padding: 6px 12px;
            border: 1px solid #e5e7eb;
            vertical-align: middle;
        }

        tr:hover td {
            background-color: #f9fafb;
        }

        /* Tahrirlash qatori elementlari */
        .edit-form {
            display: flex;
            align-items: center;
            gap: 4px;
            margin: 0;
        }

        .input-box {
            display: flex;
            align-items: center;
            background: #fdfdfd;
            border: 1px solid #e5e7eb;
            border-radius: 4px;
            padding: 2px 4px;
        }

        .input-box:focus-within {
            border-color: #107c41;
            background: white;
        }

        .cell-input {
            border: none;
            background: transparent;
            padding: 4px;
            font-size: 13px;
            width: 55px;
            outline: none;
            font-family: inherit;
            color: inherit;
        }

        .unit {
            font-size: 11px;
            color: #9ca3af;
            padding-right: 2px;
        }

        /* Qalamcha (Edit) tugmasi */
        .btn-cell-submit {
            background: #f3f4f6;
            border: 1px solid #d1d5db;
            color: #4b5563;
            padding: 5px 8px;
            border-radius: 4px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .btn-cell-submit:hover {
            background: #e1f1e9;
            border-color: #107c41;
            color: #107c41;
        }

        /* Savatcha (Trash) tugmasi */
        .btn-trash {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 4px;
            background: transparent;
            color: #9ca3af;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-trash:hover {
            background: #fee2e2;
            color: #ef4444;
        }

        .no-data {
            text-align: center;
            color: #9ca3af;
            padding: 20px !important;
        }
    </style>
</head>
<body>

<div class="container">
    
    <div class="toolbar">
        <div class="logo-area">🍏 Mevalar Ombori</div>
        <div class="actions-area">
            <button class="btn-toggle-form" onclick="toggleForm()">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
                Yangi meva
            </button>
            <a href="/logout" class="btn-logout">Chiqish</a>
        </div>
    </div>

    <div class="form-container" id="newMevaForm">
        <form action="/meva/qoshish" method="POST" class="excel-form">
            <input type="text" name="nomi" placeholder="Meva nomi" required>
            <input type="number" name="soni" placeholder="Soni (ta)" min="0" required>
            <input type="number" name="narxi" placeholder="Narxi (so'm)" min="0" required>
            <button type="submit" class="btn-save-new">Qo'shish</button>
        </form>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="width: 50px; text-align: center;">ID</th>
                    <th style="width: 140px;">Mahsulot Nomi</th>
                    <th>Miqdori va Narxi (O'zgartirish)</th>
                    <th style="width: 70px; text-align: center;">O'chirish</th>
                </tr>
            </thead>
            <tbody>
                <% if (mevalar && mevalar.length > 0) { %>
                    <% mevalar.forEach((meva) => { %>
                        <tr>
                            <td style="color: #6b7280; text-align: center; font-weight: 500;">#<%= meva.id %></td>
                            <td style="font-weight: 500; color: #111827;">🍏 <%= meva.nomi %></td>
                            
                            <td>
                                <form action="/meva/tahrirlash/<%= meva.id %>" method="POST" class="edit-form">
                                    <div class="input-box">
                                        <input type="number" name="soni" class="cell-input" value="<%= meva.soni %>" required>
                                        <span class="unit">ta</span>
                                    </div>
                                    <div class="input-box">
                                        <input type="number" name="narxi" class="cell-input" style="width: 75px;" value="<%= meva.narxi %>" required>
                                        <span class="unit">so'm</span>
                                    </div>
                                    <button type="submit" class="btn-cell-submit" title="Saqlash">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                                        </svg>
                                    </button>
                                </form>
                            </td>

                            <td style="text-align: center;">
                                <a href="/meva/ochirish/<%= meva.id %>" class="btn-trash" title="O'chirish" onclick="return confirm('O\'chirilsinmi?')">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="no-data">Ombor bo'sh. Mahsulot kiritilmagan.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleForm() {
        const form = document.getElementById('newMevaForm');
        form.classList.toggle('show');
    }
</script>

</body>
</html>