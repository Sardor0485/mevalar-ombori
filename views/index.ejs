<!DOCTYPE html>
<html lang="uz">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .chart-box { width: 150px; height: 150px; margin: auto; }
        .excel-input { width: 60px; text-align: center; border: 1px solid #ccc; }
    </style>
</head>
<body class="bg-light p-2">
    <div class="card p-2 mb-3 shadow-sm"><div class="chart-box"><canvas id="myChart"></canvas></div></div>

    <div class="table-responsive bg-white shadow-sm p-2 rounded">
        <table class="table table-sm align-middle">
            <thead><tr><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr></thead>
            <tbody>
                <% mevalar.forEach((m) => { %>
                <tr>
                    <td><%= m.nomi %></td>
                    <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>" class="excel-input"></td>
                    <td><input type="number" value="<%= m.narxi %>" id="narxi-<%= m.id %>" class="excel-input"></td>
                    <td>
                        <button onclick="save('<%= m.id %>')" class="btn btn-sm btn-primary">Edit</button>
                        <a href="/meva/ochirish/<%= m.id %>" class="btn btn-sm btn-danger">Del</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

<script>
    const labels = <%- JSON.stringify(mevalar.map(m => m.nomi)) %>;
    const data = <%- JSON.stringify(mevalar.map(m => m.soni)) %>;
    
    new Chart(document.getElementById('myChart'), { 
        type: 'doughnut', 
        data: { labels: labels, datasets: [{ data: data, backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56'] }] },
        options: { maintainAspectRatio: false }
    });

    function save(id) {
        fetch('/meva/tahrirlash/'+id, { 
            method: 'POST', 
            headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ soni: document.getElementById('soni-'+id).value, narxi: document.getElementById('narxi-'+id).value }) 
        }).then(() => location.reload());
    }
</script>
</body>
</html>