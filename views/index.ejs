<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: sans-serif; background: #f1f5f9; padding: 20px; }
        .container { max-width: 800px; margin: auto; background: white; padding: 20px; border-radius: 12px; }
        .chart-container { height: 300px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; border-bottom: 1px solid #ddd; text-align: left; }
        #totalDisplay { font-size: 24px; font-weight: bold; color: #10b981; margin-top: 20px; text-align: right; }
    </style>
</head>
<body>

<div class="container">
    <div class="chart-container">
        <canvas id="myChart"></canvas>
    </div>
    
    <div id="totalDisplay">Jami: 0 so'm</div>

    <table>
        <thead>
            <tr><th>Meva</th><th>Soni</th><th>Narxi</th><th>Jami</th></tr>
        </thead>
        <tbody>
            <% mevalar.forEach((meva) => { %>
                <tr class="meva-row">
                    <td><%= meva.nomi %></td>
                    <td class="soni"><%= meva.soni %></td>
                    <td class="narxi"><%= meva.narxi %></td>
                    <td><%= (meva.soni * meva.narxi).toLocaleString() %> so'm</td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
    // 1. Chart uchun ma'lumotlarni xatosiz olish
    const labels = [<% mevalar.forEach(m => { %> '<%= m.nomi %>', <% }) %>];
    const data = [<% mevalar.forEach(m => { %> <%= m.soni %>, <% }) %>];

    // 2. Chartni ishga tushirish
    const ctx = document.getElementById('myChart').getContext('2d');
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: ['#ff3838', '#ff9f43', '#2ed573', '#10ac84', '#00d2d3', '#54a0ff']
            }]
        }
    });

    // 3. TOTAL SUMMANI HISOBLASH (undefined bo'lmasligi uchun)
    function calculateTotal() {
        let total = 0;
        document.querySelectorAll('.meva-row').forEach(row => {
            let soni = parseFloat(row.querySelector('.soni').innerText) || 0;
            let narxi = parseFloat(row.querySelector('.narxi').innerText) || 0;
            total += (soni * narxi);
        });
        document.getElementById('totalDisplay').innerText = "Jami: " + total.toLocaleString() + " so'm";
    }

    calculateTotal();
</script>

</body>
</html>