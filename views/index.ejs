<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .chart-container { width: 150px; height: 150px; margin: auto; }
        .excel-input { width: 70px; border: 1px solid #ddd; text-align: center; border-radius: 5px; }
    </style>
</head>
<body class="bg-light p-3">
    <div class="card mb-4 p-3 shadow-sm text-center">
        <div class="chart-container"><canvas id="myChart"></canvas></div>
    </div>

    <button onclick="toggleForm()" class="btn btn-warning w-100 mb-3 fw-bold">➕ YANGI MEVA</button>
    <div id="addForm" class="card p-3 mb-3" style="display:none;">
        <form action="/meva/qoshish" method="POST" class="row g-2">
            <input name="nomi" class="form-control" placeholder="Nomi" required>
            <input type="number" name="soni" class="form-control" placeholder="Soni" required>
            <input type="number" name="narxi" class="form-control" placeholder="Narxi" required>
            <button class="btn btn-primary">Saqlash</button>
        </form>
    </div>

    <table class="table align-middle bg-white shadow-sm rounded">
        <thead class="table-dark"><tr><th>Nomi</th><th>Soni</th><th>Narxi</th><th>Amal</th></tr></thead>
        <tbody>
            <% mevalar.forEach((m) => { %>
            <tr>
                <td class="fw-bold"><%= m.nomi %></td>
                <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>" class="excel-input"></td>
                <td><input type="number" value="<%= m.narxi %>" id="narxi-<%= m.id %>" class="excel-input"></td>
                <td class="d-flex gap-2">
                    <button onclick="save('<%= m.id %>')" class="btn btn-success btn-sm"><i class="bi bi-save"></i></button>
                    <a href="/meva/ochirish/<%= m.id %>" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></a>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>

<script>
    new Chart(document.getElementById('myChart'), { type: 'doughnut', data: { labels: [<%- mevalar.map(m => `'${m.nomi}'`).join(',') %>], datasets: [{ data: [<%- mevalar.map(m => m.soni).join(',') %>], backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0'] }] }, options: { maintainAspectRatio: false } });
    function toggleForm() { document.getElementById('addForm').style.display = (document.getElementById('addForm').style.display === 'none') ? 'block' : 'none'; }
    function save(id) {
        fetch('/meva/tahrirlash/'+id, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ soni: document.getElementById('soni-'+id).value, narxi: document.getElementById('narxi-'+id).value }) }).then(() => location.reload());
    }
</script>
</body>
</html>