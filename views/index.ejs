<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <title>Ombor Boshqaruvi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 p-5">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 mb-6">📦 Ombor Statistikasi</h1>
        
        <form action="/meva/qoshish" method="POST" class="bg-white p-5 rounded-xl shadow-md mb-8 flex gap-4">
            <input type="text" name="nomi" placeholder="Meva nomi" class="border p-2 rounded w-full" required>
            <input type="number" name="narxi" placeholder="Narxi" class="border p-2 rounded w-24">
            <input type="number" name="soni" placeholder="Soni" class="border p-2 rounded w-24">
            <button class="bg-blue-600 text-white px-6 py-2 rounded font-bold hover:bg-blue-700">Qo'shish</button>
        </form>

        <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-100">
                    <tr>
                        <th class="p-4">Nomi</th>
                        <th class="p-4">Narxi (so'm)</th>
                        <th class="p-4">Soni</th>
                    </tr>
                </thead>
                <tbody>
                    <% mevalar.forEach(m => { %>
                    <tr class="border-t hover:bg-gray-50">
                        <td class="p-4 font-medium"><%= m.nomi %></td>
                        <td class="p-4 text-green-600"><%= m.narxi %></td>
                        <td class="p-4"><%= m.soni %> ta</td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>