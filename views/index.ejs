<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <title>Minimal Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .card { background: #ffffff; border: 1px solid #f0f0f0; border-radius: 20px; }
    </style>
</head>
<body class="bg-[#FAFAFA] p-6 md:p-12">

<div class="max-w-5xl mx-auto">
    <div class="flex justify-between items-end mb-10">
        <div>
            <h1 class="text-3xl font-semibold text-gray-900">Ombor</h1>
            <p class="text-gray-400">Minimalist boshqaruv paneli</p>
        </div>
        <button onclick="exportToExcel()" class="text-sm font-medium text-blue-600 hover:text-blue-800 transition">Yuklab olish ↗</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="card p-6 shadow-sm">
            <span class="text-gray-400 text-xs uppercase tracking-widest">Jami Summa</span>
            <div class="text-2xl font-semibold mt-1" id="totalSum">0</div>
        </div>
    </div>

    <input type="text" id="searchInput" placeholder="Qidirish..." class="w-full bg-white border border-gray-100 rounded-xl p-4 mb-6 shadow-sm outline-none focus:border-blue-200 transition">

    <div class="card p-2 overflow-x-auto">
        <table class="w-full text-left border-collapse" id="mevaTable">
            <thead>
                <tr class="text-gray-400 text-xs uppercase">
                    <th class="p-4">Tanlash</th>
                    <th class="p-4">Nomi</th>
                    <th class="p-4">Narxi</th>
                    <th class="p-4">Soni</th>
                </tr>
            </thead>
            <tbody>
                <% mevalar.forEach(m => { %>
                <tr class="hover:bg-gray-50 transition border-t border-gray-50">
                    <td class="p-4"><input type="checkbox" class="rowCheckbox w-4 h-4 accent-blue-500" data-price="<%= m.narxi %>" data-count="<%= m.soni %>"></td>
                    <td class="p-4 font-medium text-gray-700"><%= m.nomi %></td>
                    <td class="p-4 text-gray-500"><%= m.narxi %></td>
                    <td class="p-4 text-gray-500"><%= m.soni %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
    // Qidiruv
    document.getElementById('searchInput').addEventListener('keyup', e => {
        const val = e.target.value.toLowerCase();
        document.querySelectorAll('tbody tr').forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
        });
    });

    // Summa
    document.querySelectorAll('.rowCheckbox').forEach(cb => {
        cb.addEventListener('change', () => {
            let total = 0;
            document.querySelectorAll('.rowCheckbox:checked').forEach(c => {
                total += (parseFloat(c.dataset.price) * parseFloat(c.dataset.count));
            });
            document.getElementById('totalSum').innerText = total.toLocaleString() + " so'm";
        });
    });

    function exportToExcel() {
        const wb = XLSX.utils.table_to_book(document.getElementById('mevaTable'));
        XLSX.writeFile(wb, "Report.xlsx");
    }
</script>
</body>
</html>