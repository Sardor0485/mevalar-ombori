<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minimalist Dashboard</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #fafafa;
            color: #111111;
            margin: 0;
            padding: 50px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 850px;
        }

        /* Yengil va toza Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 20px;
        }

        h1 {
            font-size: 22px;
            font-weight: 600;
            margin: 0;
            color: #111;
        }

        .logout-btn {
            font-size: 13px;
            color: #666;
            text-decoration: none;
            padding: 6px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: white;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            color: #111;
            border-color: #111;
        }

        /* Minimal Forma */
        .form-card {
            background: white;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            margin-bottom: 30px;
        }

        .form-card h3 {
            margin: 0 0 15px 0;
            font-size: 14px;
            font-weight: 600;
            color: #4b5563;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .form-group input {
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding: 10px 14px;
            font-size: 14px;
            flex: 1;
            min-width: 160px;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input:focus {
            border-color: #111;
        }

        .btn-add {
            background: #111;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
            font-weight: 500;
            transition: background 0.2s;
        }

        .btn-add:hover {
            background: #333;
        }

        /* Minimalist Jadval */
        .table-wrapper {
            background: white;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #f9fafb;
            color: #4b5563;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            padding: 14px 20px;
            border-bottom: 1px solid #e5e7eb;
            letter-spacing: 0.5px;
        }

        td {
            padding: 14px 20px;
            border-bottom: 1px solid #f3f4f6;
            font-size: 14px;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .meva-title {
            font-weight: 500;
            color: #111;
        }

        /* Tahrirlash formasi */
        .edit-form {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .edit-form input {
            border: 1px solid #e5e7eb;
            border-radius: 4px;
            padding: 6px 10px;
            width: 80px;
            font-size: 13px;
            outline: none;
        }

        .edit-form input:focus {
            border-color: #111;
        }

        .btn-update {
            background: none;
            border: 1px solid #d1d5db;
            color: #374151;
            padding: 5px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s;
        }

        .btn-update:hover {
            background: #f9fafb;
            border-color: #111;
            color: #111;
        }

        /* O'chirish havolasi */
        .btn-delete {
            color: #9ca3af;
            text-decoration: none;
            font-size: 13px;
            transition: color 0.2s;
        }

        .btn-delete:hover {
            color: #ef4444;
        }

        .no-data {
            text-align: center;
            color: #6b7280;
            padding: 30px !important;
            font-size: 14px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>Mevalar ombori</h1>
        <a href="/logout" class="logout-btn">Chiqish</a>
    </div>

    <div class="form-card">
        <h3>Yangi mahsulot qo'shish</h3>
        <form action="/meva/qoshish" method="POST" class="form-group">
            <input type="text" name="nomi" placeholder="Meva nomi" required>
            <input type="number" name="soni" placeholder="Soni (ta)" min="0" required>
            <input type="number" name="narxi" placeholder="Narxi (so'm)" min="0" required>
            <button type="submit" class="btn-add">Qo'shish</button>
        </form>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th>Nomi</th>
                    <th>Miqdori va narxi</th>
                    <th style="width: 90px; text-align: right;">Amal</th>
                </tr>
            </thead>
            <tbody>
                <% if (mevalar && mevalar.length > 0) { %>
                    <% mevalar.forEach(meva => { %>
                        <tr>
                            <td style="color: #9ca3af;">#<%= meva.id %></td>
                            <td><span class="meva-title"><%= meva.nomi %></span></td>
                            <td>
                                <form action="/meva/tahrirlash/<%= meva.id %>" method="POST" class="edit-form">
                                    <input type="number" name="soni" value="<%= meva.soni %>" required> <span style="color: #9ca3af;">ta</span>
                                    <input type="number" name="narxi" value="<%= meva.narxi %>" required> <span style="color: #9ca3af;">so'm</span>
                                    <button type="submit" class="btn-update">Saqlash</button>
                                </form>
                            </td>
                            <td style="text-align: right;">
                                <a href="/meva/ochirish/<%= meva.id %>" class="btn-delete" onclick="return confirm('O\'chirilsinmi?')">O'chirish</a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="no-data">Mahsulotlar mavjud emas.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

</body>
</html>