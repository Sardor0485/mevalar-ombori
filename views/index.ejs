<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meva Ombori</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #f4f7f6; }
        .chart-container { width: 150px; height: 150px; margin: auto; }
        .main-card { background: white; border-radius: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .table-responsive { border-radius: 15px; overflow: hidden; }
        input[type="number"] { width: 100%; border: 1px solid #ced4da; border-radius: 8px; text-align: center; }
        @media (max-width: 576px) {
            .btn-save { padding: 5px 10px; font-size: 0.8rem; }
        }
    </style>
</head>
<body class="p-3">

<div class="container-fluid max-w-lg">
    <div class="main-card p-4 mb-4 text-center">
        <h5 class="text-secondary mb-3">Ombor Holati</h5>
        <div class="chart-container"><canvas id="myChart"></canvas></div>
    </div>

    <div class="main-card p-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nomi</th>
                        <th>Soni</th>
                        <th>Narxi</th>
                        <th>Amal</th>
                    </tr>
                </thead>
                <tbody>
                    <% mevalar.forEach((m) => { %>
                    <tr>
                        <td class="fw-bold"><%= m.nomi %></td>
                        <td><input type="number" value="<%= m.soni %>" id="soni-<%= m.id %>"></td>
                        <td><input type="number" value="<%= m.narxi %>" id="narxi-<%= m.id %>"></td>
                        <td>
                            <button onclick="save('<%= m.id %>')" class="btn btn-primary btn-sm btn-save">Saqlash</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Chart.js sozlamasi
    new Chart(document.getElementById('myChart'), { 
        type: 'doughnut', 
        data: { 
            labels: [<%- mevalar.map(m => `'${m.nomi}'`).join(',') %>], 
            datasets: [{ 
                data: [<%- mevalar.map(m => m.soni).join(',') %>], 
                backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF'] 
            }] 
        },
        options: { 
            responsive: true,
            maintainAspectRatio: false 
        }
    });

    // Saqlash funksiyasi
    function save(id) {
        fetch('/meva/tahrirlash/'+id, { 
            method: 'POST', 
            headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ 
                soni: document.getElementById('soni-'+id).value, 
                narxi: document.getElementById('narxi-'+id).value 
            }) 
        }).then(() => {
            alert("Muvaffaqiyatli yangilandi!");
            location.reload();
        });
    }
</script>
</body>
</html>