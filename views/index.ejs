<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ombor Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: sans-serif; background: #f1f5f9; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        .container { max-width: 800px; width: 100%; background: white; padding: 20px; border-radius: 12px; }
        .chart-container { height: 250px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        td, th { padding: 12px; border-bottom: 1px solid #eee; }
        #totalDisplay { font-size: 22px; font-weight: 800; color: #10b981; margin-top: 15px; text-align: right; }
    </style>
</head>
<body>

<div class="container">
    <div class="chart-container">
        <canvas id="myChart"></canvas>
    </div>
    
    <div id="totalDisplay">Jami: 0 so'm</div>

    <table>
        <thead>
            <tr><th>Tanlash</th><th>Meva</th><th>Soni</th><th>Narxi</th></tr>
        </thead>
        <tbody>
            <% mevalar.forEach((meva) => { %>
                <tr class="meva-row">
                    <td><input type="radio" name="selectMeva" class="radio-select" 
                               data-price="<%= meva.narxi %>" 
                               data-count="<%= meva.soni %>" 
                               onchange="calculateTotal()"></td>
                    <td><%= meva.nomi %></td>
                    <td class="soni"><%= meva.soni %></td>
                    <td class="narxi"><%= meva.narxi %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
    // 1. CHARTNI ASL HOLIDA (LEGENDSIZ) ISHLATISH
    const ctx = document.getElementById('myChart').getContext('2d');
    const myChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: [<% mevalar.forEach(m => { %> '<%= m.nomi %>', <% }) %>],
            datasets: [{
                data: [<% mevalar.forEach(m => { %> <%= m.soni %>, <% }) %>],
                backgroundColor: ['#ff3838', '#ff9f43', '#2ed573', '#10ac84', '#00d2d3', '#54a0ff']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false } // TEPA QISM O'CHIRILDI
            }
        }
    });

    // 2. RADIO BUTTON ORQALI HISOBLASH
    function calculateTotal() {
        const selected = document.querySelector('.radio-select:checked');
        if (selected) {
            const price = parseFloat(selected.dataset.price) || 0;
            const count = parseFloat(selected.dataset.count) || 0;
            const total = price * count;
            document.getElementById('totalDisplay').innerText = "Tanlangan jami: " + total.toLocaleString() + " so'm";
        }
    }
</script>

</body>
</html>